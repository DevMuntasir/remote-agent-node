PORT=3000
CLIENT_ORIGIN=*
TRUST_PROXY=true

# Firebase Web App config (for browser sign-in)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=

# Visitor IP tracking / blocking
FIREBASE_VISITOR_COLLECTION=visitor_ips
BLOCKED_IP_CACHE_TTL_MS=30000

# Firebase Admin SDK service account (for server-side token verification)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""
